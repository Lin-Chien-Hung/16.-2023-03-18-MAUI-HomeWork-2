<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns          = "http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x        = "http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit  = "http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class        = "MauiApp1.DetailPage"
             Title          = "DetailPage"
             xmlns:viewmodel= "clr-namespace:MauiApp1.ViewModel"
             x:DataType     = "viewmodel:DetailViewModel">

    <!--====================================================================-->
    <StackLayout Padding="20">
        
        <!--標題-->
        <Label Text="{Binding Text}"
               FontSize="25"
               VerticalOptions="Center"
               HorizontalOptions="Center" />

        <!--按鈕-->
        <Button Text="Go Back"
                Command="{Binding GoBackCommand}"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

        <BoxView HeightRequest="20" Opacity="0" />
        
        <!--鏡頭-->
        <!--<Grid ColumnDefinitions="*,*,*" RowDefinitions="*,30,30">
            <toolkit:CameraView x:Name="myCamera" MediaCaptured="myCamera_MediaCaptured" />
        </Grid>-->
        <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,30,30">
            <toolkit:CameraView 
                x:Name="myCamera" 
                MediaCaptured="myCamera_MediaCaptured"
                Grid.ColumnSpan="3"
                Grid.Row="0"
                Grid.RowSpan="1"
                HorizontalOptions="FillAndExpand"
                VerticalOptions="FillAndExpand" />
        </Grid>
        
        <!--拍照-->
        <Button CornerRadius="360"
                x:Name="click"
                Clicked="click_Clicked"
                HeightRequest="50" WidthRequest="50"
                />

        <!--<Image x:Name="ncameraimage" HeightRequest="50" WidthRequest="50" />-->

        <Grid RowDefinitions="0.4*,0.6*">
            <Image x:Name="ncameraimage" Grid.Row="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Aspect="AspectFill"/>
        </Grid>

        <!--功能-->
        <HorizontalStackLayout>
            <Button x:Name="flash" Text="Flash" Clicked="flash_Clicked" />
            <Button x:Name="zoomin" Text="+" Clicked="zoomin_Clicked" />
            <Button x:Name="zoomout" Text="-" Clicked="zoomout_Clicked" />
        </HorizontalStackLayout>
        
        <BoxView HeightRequest="20" Opacity="0" />
        
        <Button x:Name="switch" Text="switch" Clicked="switch_Clicked" />
        
    </StackLayout>
    <!--====================================================================-->

</ContentPage>