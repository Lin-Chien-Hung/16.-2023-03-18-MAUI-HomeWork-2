<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns          = "http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x        = "http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit  = "http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class        = "MauiApp1.DetailPage"
             Title          = "DetailPage"
             xmlns:viewmodel= "clr-namespace:MauiApp1.ViewModel"
             x:DataType     = "viewmodel:DetailViewModel">

    <!--====================================================================-->
    <ScrollView Margin="20">
        
        <StackLayout Padding="20">

            <!--標題-->
            <Label Text="{Binding Text}"
               FontSize="25"
               VerticalOptions="Center"
               HorizontalOptions="Center" />

            <!--按鈕-->
            <Button Text="Go Back"
                Command="{Binding GoBackCommand}"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <!--加入空白 => Padding-->
            <BoxView HeightRequest="20" Opacity="0" />

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,30,30">
                <toolkit:CameraView 
                x:Name="myCamera" 
                MediaCaptured="myCamera_MediaCaptured"
                Grid.ColumnSpan="3"
                Grid.Row="0"
                Grid.RowSpan="1"
                HorizontalOptions="FillAndExpand"
                VerticalOptions="FillAndExpand" />
            </Grid>

            <!--拍照-->
            <Button CornerRadius="360" x:Name="click" Clicked="click_Clicked" HeightRequest="50" WidthRequest="50" />

            <Grid RowDefinitions="*">
                <Image x:Name="ncameraimage" Grid.Row="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Aspect="AspectFit"/> <!--AspectFill 畫面可能裁切-->
            </Grid>

            <Label x:Name="locationLabel" FontSize="16" TextColor="Gray" />

            <!--功能-->
            <HorizontalStackLayout IsVisible="False">
                <Button x:Name="flash" Text="Flash" Clicked="flash_Clicked" />
                <Button x:Name="zoomin" Text="+" Clicked="zoomin_Clicked" />
                <Button x:Name="zoomout" Text="-" Clicked="zoomout_Clicked" />
            </HorizontalStackLayout>
            
            <!--加入空白 => Padding-->
            <BoxView HeightRequest="20" Opacity="0" />

            <Button x:Name="switch" Text="switch" Clicked="switch_Clicked" IsVisible="False" />

        </StackLayout>
        
    </ScrollView>
    <!--====================================================================-->

</ContentPage>